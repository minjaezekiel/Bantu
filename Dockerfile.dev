# ════════════════════════════════════════════════════════════════════
#  ChatBantu — Local Development Dockerfile (fast iteration)
#
#  Unlike the production Dockerfile (multi-stage, builds Bantu from source),
#  this one assumes a PREBUILT bantu binary in the repo root and just copies
#  it into a minimal Ubuntu 22.04 image with the runtime libraries.
#
#  Build time: ~5 seconds (vs ~3 minutes for the production Dockerfile).
#  Use for local development only. For Render, use the main Dockerfile.
# ════════════════════════════════════════════════════════════════════

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Africa/Dar_es_Salaam
ENV PORT=8080

# Runtime libraries only — no build tools, no dev headers.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        libsqlite3-0 \
        libcurl4 \
        ca-certificates \
        sqlite3 \
        curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy prebuilt binary + app
COPY bantu   /usr/local/bin/bantu
COPY server.b /app/server.b
COPY public/  /app/public/

RUN chmod +x /usr/local/bin/bantu

# SQLite will be written here in the container (use a volume to persist)
RUN mkdir -p /data && chmod 777 /data

EXPOSE 8080

# Quick smoke test before CMD
RUN /usr/local/bin/bantu --version

CMD ["bantu", "run", "server.b"]
