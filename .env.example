# ────────────────────────────────────────────────────────────────────
#  ChatBantu — Environment variables (copy to .env and customize)
#  Copy:  cp .env.example .env
#  Then edit values as needed. The dev.sh / docker-compose.dev.yml
#  read .env automatically.
# ────────────────────────────────────────────────────────────────────

# Port the Bantu HTTP server listens on (Render injects this; locally, default 8080)
PORT=8080

# SQLite database path. Default = ./chatbantu.db (next to server.b).
# On Render, the persistent volume is mounted at /data, so set:
#   DB_PATH=/data/chatbantu.db
DB_PATH=./chatbantu.db

# Optional: log level (info|debug|warn|error). Default: info.
# Currently informational only — Bantu prints all routes regardless.
LOG_LEVEL=info
